{
  "name": "ephemeral-sandbox-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "assets:generate": "node scripts/assets.mjs generate",
    "assets:verify": "node scripts/assets.mjs verify",
    "assets:verify-dist": "node scripts/assets.mjs verify-dist",
    "prebuild": "npm run assets:verify",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "npm run assets:verify-dist",
    "preview": "vite preview",
    "pretest": "npm run assets:verify",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests",
    "tauri": "cd ../desktop && tauri",
    "test:fixture:serve": "vite tests/p00 --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --grep @a11y",
    "test:security": "playwright test --grep @security",
    "test:visual": "playwright test --grep @visual"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@mantine/core": "9.4.1",
    "@mantine/hooks": "9.4.1",
    "@mantine/notifications": "9.4.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@tauri-apps/cli": "2.11.4",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "sharp": "0.35.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "24.x"
  }
}
