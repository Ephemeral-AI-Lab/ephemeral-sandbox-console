#!/bin/sh
set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd "$script_dir/.." && pwd)
export PATH="$repo_root/bin:$PATH"

bind=${SANDBOX_CONSOLE_BIND:-127.0.0.1:7880}
pid_file=${SANDBOX_CONSOLE_PID_FILE:-/tmp/eos-console.pid}
log_file=${SANDBOX_CONSOLE_LOG:-/tmp/eos-console.log}
skip_gateway=0
skip_spa=0
gateway_args=
core_root=

usage() {
    printf 'start-sandbox-console-stack [--skip-gateway] [--skip-spa] [--bind HOST:PORT] [--rebuild-binary]\n\n'
    printf '  --skip-gateway    do not (re)start the gateway; keep the running one\n'
    printf '  --skip-spa        do not rebuild the SPA even if sources changed\n'
    printf '  --bind HOST:PORT  console bind address (default %s)\n' "$bind"
    printf '  --rebuild-binary  forwarded to the core Docker gateway launcher\n'
    printf '\nSet EPHEMERAL_SANDBOX_ROOT to the core checkout; the sibling checkout is the default.\n'
}

resolve_core_root() {
    if [ -n "$core_root" ]; then
        return
    fi
    core_candidate=${EPHEMERAL_SANDBOX_ROOT:-$repo_root/../ephemeral-sandbox}
    if ! core_root=$(CDPATH= cd "$core_candidate" 2>/dev/null && pwd); then
        printf 'Ephemeral Sandbox checkout not found at %s; set EPHEMERAL_SANDBOX_ROOT\n' \
            "$core_candidate" >&2
        exit 1
    fi
}

load_gateway_token() {
    if [ -n "${SANDBOX_GATEWAY_AUTH_TOKEN:-}" ]; then
        return
    fi
    resolve_core_root
    token_helper=$core_root/bin/sandbox-gateway-token
    if [ ! -f "$token_helper" ]; then
        printf 'gateway token helper not found at %s; set SANDBOX_GATEWAY_AUTH_TOKEN\n' \
            "$token_helper" >&2
        exit 1
    fi
    . "$token_helper"
    sandbox_gateway_token_load
    if [ -z "${SANDBOX_GATEWAY_AUTH_TOKEN:-}" ]; then
        printf 'gateway auth token is unavailable; set SANDBOX_GATEWAY_AUTH_TOKEN\n' >&2
        exit 1
    fi
}

while [ $# -gt 0 ]; do
    case "$1" in
        --skip-gateway) skip_gateway=1 ;;
        --skip-spa) skip_spa=1 ;;
        --bind)
            shift
            if [ $# -eq 0 ]; then
                printf '%s\n' '--bind requires a value' >&2
                exit 2
            fi
            bind=$1
            ;;
        --bind=*) bind=${1#--bind=} ;;
        --rebuild-binary) gateway_args=--rebuild-binary ;;
        -h|--help) usage; exit 0 ;;
        *) printf 'unknown option %s\n\n' "$1" >&2; usage >&2; exit 2 ;;
    esac
    shift
done

if [ "$skip_gateway" -eq 0 ]; then
    resolve_core_root
    gateway_launcher=$core_root/bin/start-sandbox-docker-gateway
    if [ ! -x "$gateway_launcher" ]; then
        printf 'core Docker gateway launcher is not executable: %s\n' "$gateway_launcher" >&2
        exit 1
    fi
    if ! docker info >/dev/null 2>&1; then
        printf 'docker daemon is not reachable; start Docker first (or pass --skip-gateway)\n' >&2
        exit 1
    fi
    printf '==> starting sandbox gateway from %s\n' "$core_root"
    if [ -n "$gateway_args" ]; then
        "$gateway_launcher" "$gateway_args"
    else
        "$gateway_launcher"
    fi
else
    printf '==> keeping the running gateway (--skip-gateway)\n'
fi

load_gateway_token

spa_index=$repo_root/dist/console/index.html
if [ "$skip_spa" -eq 1 ]; then
    printf '==> keeping existing SPA assets (--skip-spa)\n'
else
    needs_spa=0
    if [ ! -f "$spa_index" ]; then
        needs_spa=1
    else
        newer_spa_source=$(
            find \
                "$repo_root/web/src" \
                "$repo_root/web/public" \
                "$repo_root/web/package.json" \
                "$repo_root/web/package-lock.json" \
                "$repo_root/web/vite.config.ts" \
                "$repo_root/web/tsconfig.app.json" \
                "$repo_root/web/tsconfig.json" \
                "$repo_root/web/tsconfig.node.json" \
                "$repo_root/web/index.html" \
                -type f -newer "$spa_index" -print -quit 2>/dev/null
        )
        if [ -n "$newer_spa_source" ]; then
            needs_spa=1
        fi
    fi
    if [ "$needs_spa" -eq 1 ]; then
        printf '==> building SPA assets\n'
        "$repo_root/bin/package-console" --assets-only
    else
        printf '==> SPA assets are up to date (dist/console)\n'
    fi
fi

printf '==> building sandbox-console\n'
(cd "$repo_root" && cargo build --locked --quiet -p sandbox-console --bin sandbox-console)

stop_existing_console() {
    [ -f "$pid_file" ] || return 0
    old_pid=$(sed -n '1p' "$pid_file" 2>/dev/null || true)
    case "$old_pid" in
        ''|*[!0-9]*) rm -f "$pid_file"; return 0 ;;
    esac
    if ! kill -0 "$old_pid" 2>/dev/null; then
        rm -f "$pid_file"
        return 0
    fi
    process_name=$(ps -p "$old_pid" -o comm= 2>/dev/null || true)
    case "$process_name" in
        *sandbox-console*) ;;
        *)
            printf 'stale pid file %s points at non-console process %s; not killing\n' \
                "$pid_file" "$old_pid" >&2
            rm -f "$pid_file"
            return 0
            ;;
    esac
    printf '==> stopping existing sandbox-console pid %s\n' "$old_pid"
    kill "$old_pid" 2>/dev/null || true
    count=0
    while kill -0 "$old_pid" 2>/dev/null && [ "$count" -lt 30 ]; do
        sleep 0.1
        count=$((count + 1))
    done
    if kill -0 "$old_pid" 2>/dev/null; then
        kill -KILL "$old_pid" 2>/dev/null || true
    fi
    rm -f "$pid_file"
}

stop_existing_console

console_port=${bind##*:}
port_pids=$(lsof -tiTCP:"$console_port" -sTCP:LISTEN 2>/dev/null || true)
for port_pid in $port_pids; do
    process_name=$(ps -p "$port_pid" -o comm= 2>/dev/null || true)
    case "$process_name" in
        *sandbox-console*)
            printf '==> stopping sandbox-console pid %s holding port %s\n' \
                "$port_pid" "$console_port"
            kill "$port_pid" 2>/dev/null || true
            count=0
            while kill -0 "$port_pid" 2>/dev/null && [ "$count" -lt 30 ]; do
                sleep 0.1
                count=$((count + 1))
            done
            if kill -0 "$port_pid" 2>/dev/null; then
                kill -KILL "$port_pid" 2>/dev/null || true
            fi
            ;;
        *)
            printf 'port %s is held by non-console process %s (%s); refusing to start\n' \
                "$console_port" "$port_pid" "$process_name" >&2
            exit 1
            ;;
    esac
done

printf '==> starting sandbox-console on %s\n' "$bind"
if command -v python3 >/dev/null 2>&1; then
    console_pid=$(
        CONSOLE_BIN=$repo_root/bin/start-sandbox-console BIND=$bind LOG_FILE=$log_file python3 - <<'PY'
import os
import subprocess

log = open(os.environ["LOG_FILE"], "ab", buffering=0)
process = subprocess.Popen(
    ["nohup", os.environ["CONSOLE_BIN"], "--bind", os.environ["BIND"]],
    stdin=subprocess.DEVNULL,
    stdout=log,
    stderr=subprocess.STDOUT,
    start_new_session=True,
    close_fds=True,
)
print(process.pid)
PY
    )
else
    nohup "$repo_root/bin/start-sandbox-console" --bind "$bind" \
        </dev/null >>"$log_file" 2>&1 &
    console_pid=$!
fi
printf '%s\n' "$console_pid" >"$pid_file"

count=0
until curl -sf -o /dev/null "http://$bind/api/catalog" 2>/dev/null; do
    if ! kill -0 "$console_pid" 2>/dev/null; then
        printf 'sandbox-console failed to stay running; see log: %s\n' "$log_file" >&2
        tail -20 "$log_file" >&2 2>/dev/null || true
        exit 1
    fi
    if [ "$count" -ge 100 ]; then
        printf 'sandbox-console did not answer on %s within 10s; see log: %s\n' \
            "$bind" "$log_file" >&2
        exit 1
    fi
    sleep 0.1
    count=$((count + 1))
done

if ! kill -0 "$console_pid" 2>/dev/null; then
    printf 'something else answered on %s but the new sandbox-console died; see log: %s\n' \
        "$bind" "$log_file" >&2
    tail -20 "$log_file" >&2 2>/dev/null || true
    exit 1
fi

printf '\nweb console ready: http://%s\n' "$bind"
printf 'console pid: %s (pid file %s)\n' "$console_pid" "$pid_file"
printf 'console log: %s\n' "$log_file"
printf 'stop with: kill %s\n' "$console_pid"
