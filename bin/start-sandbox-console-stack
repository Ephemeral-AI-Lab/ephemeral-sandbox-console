#!/bin/sh
# Bootstrap the whole web console stack in dependency order:
#   1. sandbox gateway (Docker backend; repackages the daemon when sources changed)
#   2. SPA assets (xtask package-console, skipped when dist/console is fresh)
#   3. sandbox-console server (background, with the gateway's current auth token)
#
# The console reads the gateway auth token at startup, so it is always
# (re)started after the gateway here — a gateway restart rotates the token.
set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd "$script_dir/.." && pwd)
export PATH="$repo_root/bin:$PATH"

bind=${SANDBOX_CONSOLE_BIND:-127.0.0.1:7880}
pid_file=${SANDBOX_CONSOLE_PID_FILE:-/tmp/eos-console.pid}
log_file=${SANDBOX_CONSOLE_LOG:-/tmp/eos-console.log}
skip_gateway=0
skip_spa=0
gateway_args=""

usage() {
    printf 'start-sandbox-console-stack [--skip-gateway] [--skip-spa] [--bind HOST:PORT] [--rebuild-binary]\n\n'
    printf '  --skip-gateway    do not (re)start the gateway; keep the running one\n'
    printf '  --skip-spa        do not rebuild the SPA even if sources changed\n'
    printf '  --bind HOST:PORT  console bind address (default %s)\n' "$bind"
    printf '  --rebuild-binary  forwarded to start-sandbox-docker-gateway\n'
}

while [ $# -gt 0 ]; do
    case "$1" in
        --skip-gateway) skip_gateway=1 ;;
        --skip-spa) skip_spa=1 ;;
        --bind)
            shift
            [ $# -gt 0 ] || { printf -- '--bind requires a value\n' >&2; exit 2; }
            bind=$1
            ;;
        --bind=*) bind=${1#--bind=} ;;
        --rebuild-binary) gateway_args="--rebuild-binary" ;;
        -h|--help) usage; exit 0 ;;
        *) printf 'unknown option %s\n\n' "$1" >&2; usage >&2; exit 2 ;;
    esac
    shift
done

# ---- 1. gateway -----------------------------------------------------------
if [ "$skip_gateway" -eq 0 ]; then
    if ! docker info >/dev/null 2>&1; then
        printf 'docker daemon is not reachable; start Docker first (or pass --skip-gateway)\n' >&2
        exit 1
    fi
    printf '==> starting sandbox gateway\n'
    # shellcheck disable=SC2086
    "$repo_root/bin/start-sandbox-docker-gateway" $gateway_args
else
    printf '==> keeping the running gateway (--skip-gateway)\n'
fi

# ---- 2. SPA assets --------------------------------------------------------
spa_index=$repo_root/dist/console/index.html
if [ "$skip_spa" -eq 1 ]; then
    printf '==> keeping existing SPA assets (--skip-spa)\n'
else
    needs_spa=0
    if [ ! -f "$spa_index" ]; then
        needs_spa=1
    else
        newer_spa_source=$(
            find \
                "$repo_root/web/console/src" \
                "$repo_root/web/console/package.json" \
                "$repo_root/web/console/vite.config.ts" \
                "$repo_root/web/console/index.html" \
                -type f -newer "$spa_index" -print -quit 2>/dev/null
        )
        [ -z "$newer_spa_source" ] || needs_spa=1
    fi
    if [ "$needs_spa" -eq 1 ]; then
        printf '==> building SPA assets (xtask package-console)\n'
        (cd "$repo_root" && cargo run -p xtask -- package-console)
    else
        printf '==> SPA assets are up to date (dist/console)\n'
    fi
fi

# ---- 3. console server ----------------------------------------------------
printf '==> building sandbox-console\n'
cargo build --quiet --manifest-path "$repo_root/Cargo.toml" -p sandbox-console --bin sandbox-console

stop_existing_console() {
    [ -f "$pid_file" ] || return 0
    old_pid=$(sed -n '1p' "$pid_file" 2>/dev/null || true)
    case "$old_pid" in
        ''|*[!0-9]*) rm -f "$pid_file"; return 0 ;;
    esac
    if ! kill -0 "$old_pid" 2>/dev/null; then
        rm -f "$pid_file"
        return 0
    fi
    process_name=$(ps -p "$old_pid" -o comm= 2>/dev/null || true)
    case "$process_name" in
        *sandbox-console*) ;;
        *)
            printf 'stale pid file %s points at non-console process %s; not killing\n' "$pid_file" "$old_pid" >&2
            rm -f "$pid_file"
            return 0
            ;;
    esac
    printf '==> stopping existing sandbox-console pid %s\n' "$old_pid"
    kill "$old_pid" 2>/dev/null || true
    count=0
    while kill -0 "$old_pid" 2>/dev/null && [ "$count" -lt 30 ]; do
        sleep 0.1
        count=$((count + 1))
    done
    kill -0 "$old_pid" 2>/dev/null && kill -KILL "$old_pid" 2>/dev/null
    rm -f "$pid_file"
}

stop_existing_console

# Also stop a console holding the bind port without a pid file (e.g. one
# started by hand via start-sandbox-console).
console_port=${bind##*:}
port_pids=$(lsof -tiTCP:"$console_port" -sTCP:LISTEN 2>/dev/null || true)
for port_pid in $port_pids; do
    process_name=$(ps -p "$port_pid" -o comm= 2>/dev/null || true)
    case "$process_name" in
        *sandbox-console*)
            printf '==> stopping sandbox-console pid %s holding port %s\n' "$port_pid" "$console_port"
            kill "$port_pid" 2>/dev/null || true
            count=0
            while kill -0 "$port_pid" 2>/dev/null && [ "$count" -lt 30 ]; do
                sleep 0.1
                count=$((count + 1))
            done
            kill -0 "$port_pid" 2>/dev/null && kill -KILL "$port_pid" 2>/dev/null
            ;;
        *)
            printf 'port %s is held by non-console process %s (%s); refusing to start\n' \
                "$console_port" "$port_pid" "$process_name" >&2
            exit 1
            ;;
    esac
done

printf '==> starting sandbox-console on %s\n' "$bind"
nohup "$repo_root/bin/start-sandbox-console" --bind "$bind" >>"$log_file" 2>&1 &
console_pid=$!
printf '%s\n' "$console_pid" >"$pid_file"

count=0
until curl -sf -o /dev/null "http://$bind/api/catalog" 2>/dev/null; do
    if ! kill -0 "$console_pid" 2>/dev/null; then
        printf 'sandbox-console failed to stay running; see log: %s\n' "$log_file" >&2
        tail -20 "$log_file" >&2 2>/dev/null || true
        exit 1
    fi
    if [ "$count" -ge 100 ]; then
        printf 'sandbox-console did not answer on %s within 10s; see log: %s\n' "$bind" "$log_file" >&2
        exit 1
    fi
    sleep 0.1
    count=$((count + 1))
done

if ! kill -0 "$console_pid" 2>/dev/null; then
    printf 'something else answered on %s but the new sandbox-console died; see log: %s\n' "$bind" "$log_file" >&2
    tail -20 "$log_file" >&2 2>/dev/null || true
    exit 1
fi

printf '\nweb console ready: http://%s\n' "$bind"
printf 'console pid: %s (pid file %s)\n' "$console_pid" "$pid_file"
printf 'console log: %s\n' "$log_file"
printf 'stop with: kill %s\n' "$console_pid"
