{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ephemeral Sandbox",
  "version": "0.1.0",
  "identifier": "ai.ephemeral.sandbox",
  "build": {
    "beforeDevCommand": {
      "script": "npm --prefix ../web run build",
      "wait": true
    },
    "beforeBuildCommand": "npm --prefix ../web run build"
  },
  "app": {
    "windows": [],
    "security": {
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../web/dist/": "web-dist/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
